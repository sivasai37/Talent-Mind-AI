# Django Backend Configurations Example
DJANGO_SECRET_KEY=dev-secret-key-change-me
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=*

# Database Setup
USE_POSTGRES=False
DATABASE_URL=

# PostgreSQL Manual Setup (if USE_POSTGRES=True and DATABASE_URL is not set)
POSTGRES_DB=talentmind
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# CORS Configuration
CORS_ALLOWED_ORIGINS=http://localhost:5173
CORS_ALLOW_ALL_ORIGINS=True
SECURE_SSL_REDIRECT=False

# API Keys
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
HF_TOKEN=
