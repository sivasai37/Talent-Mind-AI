# --- TalentMind AI Production Environment Variables Example ---

# --- Django Backend Configurations ---
# Secure secret key for production (random 50 char string)
DJANGO_SECRET_KEY=production-secret-key-change-me-to-something-secure
DJANGO_DEBUG=False
# Comma-separated list of allowed domains
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,talent-mind-api.render.com,your-domain.com

# --- Database Configs ---
# Toggle PostgreSQL or SQLite
USE_POSTGRES=False
# Or pass PostgreSQL URL directly (Render/Railway automatically sets this)
DATABASE_URL=postgres://user:password@host:port/dbname

# PostgreSQL manual connection parameters (if USE_POSTGRES=True and DATABASE_URL is not set)
POSTGRES_DB=talentmind
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=db
POSTGRES_PORT=5432

# --- Third-party Integration API Keys ---
# Required for online LLM recruiter summaries (optional fallback is used if empty)
GEMINI_API_KEY=your-google-gemini-api-key
GEMINI_MODEL=gemini-1.5-flash
# Optional Hugging Face Hub token to enable faster model download / higher rate limits
HF_TOKEN=your-huggingface-token

# --- CORS & Security Configurations ---
# Comma-separated allowed frontend origins
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,https://talent-mind.render.com,https://your-frontend-domain.com
CORS_ALLOW_ALL_ORIGINS=False
# Force SSL redirects (enable if behind HTTPS load balancer)
SECURE_SSL_REDIRECT=False

# --- Frontend Configurations ---
# Base API URL used by the Vite React application
VITE_API_BASE=http://localhost:8000/api
